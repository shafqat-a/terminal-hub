# Terminal Hub configuration.
#
# Install to /etc/terminal-hub.env, edit the values, then lock it down:
#   sudo install -m 600 -o root -g root terminal-hub.env.example /etc/terminal-hub.env
#   sudoedit /etc/terminal-hub.env
#
# See crates/server/src/config.rs for the full list of supported variables.

# Login password for the web UI. CHANGE THIS.
AI_CONDUCTOR_PASSWORD=changeme

# Address the server binds to (front it with nginx/caddy for TLS).
AI_CONDUCTOR_ADDR=127.0.0.1:8080

# URL prefix the app is served under.
AI_CONDUCTOR_BASE_PATH=/terminal

# Where sessions, the SQLite DB, and the tmux socket live. The tmux unit reads
# this same value, so both units agree on the socket path.
AI_CONDUCTOR_DATA_DIR=/home/youruser/.local/share/terminal-hub/sessions

# Shell launched inside new sessions.
AI_CONDUCTOR_SHELL=/bin/bash

RUST_LOG=info
